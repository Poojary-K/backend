# Copy values into your main backend `.env` (or export before compose) so Docker and scripts match.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=funds
POSTGRES_PORT=5432

# App connection string (must match user/password/db above). Encode special chars in password (e.g. @ → %40).
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/funds
